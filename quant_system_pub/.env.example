# ── 复制本文件为 .env，填入你自己的值 ──────────────────────
# cp .env.example .env   （Linux/macOS）
# copy .env.example .env  （Windows）

# ── Ollama 本地大模型（B块新闻AI分析用）────────────────────
# 填写运行 Ollama 的机器地址，本机则填 http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# ── tdx2db 本地数据库路径（可选，不填则走网络接口）─────────
# Windows 示例：TDX_DB_PATH=C:/tdx/tdx.db
# Linux   示例：TDX_DB_PATH=/home/user/tdx/tdx.db
# macOS   示例：TDX_DB_PATH=/Users/user/tdx/tdx.db
TDX_DB_PATH=

# ── 日志级别（DEBUG / INFO / WARNING）──────────────────────
LOG_LEVEL=WARNING
