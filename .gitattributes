# 统一换行符：仓库存 LF，Windows checkout 时自动转 CRLF，提交时转回 LF
* text=auto eol=lf

# Python / YAML / JSON / Shell 强制 LF
*.py    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.env   text eol=lf
.gitignore text eol=lf

# 二进制文件不做换行处理
*.pkl   binary
*.db    binary
*.duckdb binary
*.pyc   binary
*.exe   binary
*.zip   binary
*.tar.gz binary
